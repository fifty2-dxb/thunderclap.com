NEXT_PUBLIC_SITE_URL=https://thunderclap.com
NEXT_PUBLIC_GTM_ID=
LEAD_WEBHOOK_URL=

# ---- Contact form email (Zoho SMTP via nodemailer) ----
# Use an APP-SPECIFIC password (Zoho → Settings → Security → App Passwords),
# not your login password — required when 2FA is on.
ZOHO_EMAIL=
ZOHO_PASSWORD=
# Optional — where contact messages are delivered (default support@thunderclap.com).
CONTACT_TO=
# Optional — smtp.zoho.com (default) / smtp.zoho.eu / smtp.zoho.in per data centre.
ZOHO_SMTP_HOST=smtp.zoho.com

# ---- WebEngage ----
# Docs: https://docs.webengage.com/docs/rest-api-tracking-events
WEBENGAGE_API_HOST=https://api.webengage.com
WEBENGAGE_LICENSE_CODE=
WEBENGAGE_API_KEY=
# Client-side JS SDK license code (exposed to the browser, drives webengage.track / user.login)
NEXT_PUBLIC_WEBENGAGE_LICENSE_CODE=

# ---- Redlap (Social Empire Pay) ----
# Sandbox: https://sa-b084fe3ea34a4a86be5e2766f8f09494.ecs.eu-central-1.on.aws
# Production default: https://api.redlap.xyz
# Do NOT include a trailing /api/ — the client appends /api/payments/sessions itself.
REDLAP_API_BASE=https://api.redlap.xyz
REDLAP_API_KEY=
REDLAP_WEBHOOK_SECRET=
REDLAP_WEBSITE_ID=1
# Optional — defaults to NEXT_PUBLIC_SITE_URL.
REDLAP_WEBSITE_ORIGIN=
# Optional — session lifetime in seconds.
REDLAP_EXPIRES_IN=3600
